{
  "name": "pi-cas-provider",
  "version": "0.2.0",
  "description": "Pi extension that registers a Claude Agent SDK provider — uses your Claude Code auth, supports fast mode on Opus.",
  "type": "module",
  "main": "index.ts",
  "keywords": ["pi-package", "pi-extension", "claude-agent-sdk", "claude-code"],
  "pi": {
    "extensions": ["index.ts"]
  },
  "repository": "https://github.com/neevparikh/pi-cas-provider",
  "license": "MIT",
  "peerDependencies": {
    "@earendil-works/pi-ai": ">=0.70.0",
    "@earendil-works/pi-coding-agent": ">=0.70.0",
    "@earendil-works/pi-tui": ">=0.70.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.143"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.93.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "zod": "^4.0.0"
  },
  "scripts": {
    "test": "vitest run --reporter=default",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  }
}
